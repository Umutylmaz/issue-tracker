# ==============================================================
# Copy this file as .env and fill in your values
# ==============================================================

# Database (MySQL)
# Create a MySQL database and update the connection string below
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/issue-tracker"

# NextAuth
# NEXTAUTH_URL: Your app's base URL (use http://localhost:3000 for local dev)
# NEXTAUTH_SECRET: Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""